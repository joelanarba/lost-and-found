<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.DashboardController" styleClass="root">
    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    <ScrollPane fitToWidth="true" styleClass="content-scroll" HBox.hgrow="ALWAYS">
        <VBox styleClass="content-area" spacing="20.0">
            <Label text="Dashboard" styleClass="page-title"/>
            <Label fx:id="welcomeLabel" text="Welcome back" styleClass="page-subtitle"/>

            <HBox spacing="18.0">
                <VBox styleClass="stat-card" spacing="2.0" HBox.hgrow="ALWAYS" onMouseClicked="#goToBrowseLost" style="-fx-cursor: hand;">
                    <Label text="📢" styleClass="stat-icon"/>
                    <Label fx:id="openLostLabel" text="0" styleClass="stat-number"/>
                    <Label text="OPEN LOST REPORTS" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card, stat-card-found" spacing="2.0" HBox.hgrow="ALWAYS" onMouseClicked="#goToBrowseFound" style="-fx-cursor: hand;">
                    <Label text="✅" styleClass="stat-icon"/>
                    <Label fx:id="openFoundLabel" text="0" styleClass="stat-number"/>
                    <Label text="OPEN FOUND REPORTS" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card, stat-card-warning" spacing="2.0" HBox.hgrow="ALWAYS" onMouseClicked="#goToMyClaims" style="-fx-cursor: hand;">
                    <Label text="🕓" styleClass="stat-icon"/>
                    <Label fx:id="pendingClaimsLabel" text="0" styleClass="stat-number"/>
                    <Label text="MY PENDING CLAIMS" styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-card, stat-card-gold" spacing="2.0" HBox.hgrow="ALWAYS">
                    <Label text="🎯" styleClass="stat-icon"/>
                    <Label fx:id="recoveryRateLabel" text="0.0%" styleClass="stat-number"/>
                    <Label text="RECOVERY RATE" styleClass="stat-label"/>
                </VBox>
            </HBox>

            <HBox spacing="18.0">
                <VBox styleClass="insight-card" spacing="3.0">
                    <Label text="📊  MOST LOST CATEGORY" styleClass="insight-title"/>
                    <Label fx:id="topCategoryLabel" text="—" styleClass="insight-value"/>
                </VBox>
            </HBox>

            <Region prefHeight="6.0"/>
            <Label text="Suggested Matches For You" styleClass="section-title"/>
            <FlowPane fx:id="matchesPane" hgap="16.0" vgap="16.0"/>
            <Label fx:id="emptyMatchesLabel"
                   text="No matches yet. Report your items to get started."
                   styleClass="empty-state" visible="false" managed="false"/>
        </VBox>
    </ScrollPane>
</HBox>

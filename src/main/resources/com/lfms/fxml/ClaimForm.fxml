<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.ClaimFormController" styleClass="root">
    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    <ScrollPane fitToWidth="true" styleClass="content-scroll" HBox.hgrow="ALWAYS">
        <VBox styleClass="content-area" spacing="16.0">
            <Label text="Claim an Item" styleClass="page-title"/>

            <HBox styleClass="info-panel" spacing="14.0" alignment="CENTER_LEFT" maxWidth="720.0">
                <StackPane styleClass="image-frame">
                    <ImageView fx:id="thumbnail" fitWidth="80.0" fitHeight="80.0" preserveRatio="true"/>
                </StackPane>
                <VBox spacing="2.0">
                    <Label text="You are claiming:" styleClass="muted"/>
                    <Label fx:id="itemNameLabel" text="Item" styleClass="detail-value"/>
                </VBox>
            </HBox>

            <VBox fx:id="guardPanel" styleClass="warn-panel" spacing="4.0" maxWidth="720.0"
                  visible="false" managed="false">
                <Label fx:id="guardTitle" text="Claim not available" styleClass="warn-panel-title"/>
                <Label fx:id="guardMessage" wrapText="true"
                       text="You already submitted a claim for this item. Check My Reports for status."/>
            </VBox>

            <VBox fx:id="formBox" styleClass="card" spacing="8.0" maxWidth="720.0">
                <Label text="Describe specific identifying features of your item *" styleClass="form-label"/>
                <Label text="e.g. scratched corner on back-left, initials 'EK' written inside cover, custom blue sticker… (min 30 characters)"
                       styleClass="form-hint" wrapText="true"/>
                <TextArea fx:id="featuresArea" prefRowCount="4" wrapText="true"/>
                <Label fx:id="featuresError" styleClass="error-label" visible="false" managed="false"/>

                <Label text="How can you prove this is yours? *" styleClass="form-label"/>
                <Label text="e.g. purchase receipt, photos on your phone, serial number… (min 30 characters)"
                       styleClass="form-hint" wrapText="true"/>
                <TextArea fx:id="proofArea" prefRowCount="4" wrapText="true"/>
                <Label fx:id="proofError" styleClass="error-label" visible="false" managed="false"/>

                <Label text="Preferred contact method" styleClass="form-label"/>
                <TextField fx:id="contactField" promptText="e.g. WhatsApp 024 000 0000, or your email"/>

                <Region prefHeight="6.0"/>
                <HBox spacing="10.0">
                    <Button text="Submit Claim" styleClass="btn-primary" onAction="#handleSubmit"/>
                    <Button text="Cancel" styleClass="btn-secondary" onAction="#cancel"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>

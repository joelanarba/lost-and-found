<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.SidebarController"
      styleClass="sidebar" prefWidth="220.0" fillWidth="true">
    <Label text="LFMS" styleClass="sidebar-title"/>
    <Region prefHeight="8.0"/>
    <Button fx:id="btnDashboard" text="Dashboard" styleClass="sidebar-btn" onAction="#goDashboard" maxWidth="Infinity"/>
    <Button fx:id="btnReportLost" text="Report Lost" styleClass="sidebar-btn" onAction="#goReportLost" maxWidth="Infinity"/>
    <Button fx:id="btnReportFound" text="Report Found" styleClass="sidebar-btn" onAction="#goReportFound" maxWidth="Infinity"/>
    <Button fx:id="btnBrowse" text="Browse Items" styleClass="sidebar-btn" onAction="#goBrowse" maxWidth="Infinity"/>
    <Button fx:id="btnMyReports" text="My Reports" styleClass="sidebar-btn" onAction="#goMyReports" maxWidth="Infinity"/>
    <Region VBox.vgrow="ALWAYS"/>
    <Separator styleClass="sidebar-divider"/>
    <Region prefHeight="8.0"/>
    <Label fx:id="userNameLabel" text="User" styleClass="sidebar-user"/>
    <Label fx:id="userRoleLabel" text="STUDENT" styleClass="sidebar-role"/>
    <Region prefHeight="10.0"/>
    <Button fx:id="btnLogout" text="Logout" styleClass="sidebar-btn" onAction="#logout" maxWidth="Infinity"/>
    <Region prefHeight="12.0"/>
</VBox>

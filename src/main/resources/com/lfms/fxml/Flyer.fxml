<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.FlyerController" styleClass="flyer-window">
    <ScrollPane fitToWidth="true" styleClass="flyer-scroll" VBox.vgrow="ALWAYS">
        <VBox fx:id="posterNode" styleClass="flyer-poster" spacing="14.0" alignment="TOP_CENTER">
            <VBox spacing="0.0" alignment="CENTER">
                <Label text="UNIVERSITY OF CAPE COAST" styleClass="flyer-brand"/>
                <Label text="LOST &amp; FOUND NOTICE" styleClass="flyer-brand-sub"/>
            </VBox>

            <Label text="LOST ITEM" styleClass="flyer-heading"/>

            <StackPane styleClass="flyer-image-frame">
                <ImageView fx:id="flyerImage" fitWidth="300.0" fitHeight="300.0" preserveRatio="true"/>
            </StackPane>

            <Label fx:id="flyerName" styleClass="flyer-name" wrapText="true" alignment="CENTER"/>

            <VBox styleClass="flyer-details" spacing="8.0">
                <HBox spacing="8.0">
                    <Label text="Category:" styleClass="flyer-key"/>
                    <Label fx:id="flyerCategory" styleClass="flyer-val" wrapText="true"/>
                </HBox>
                <HBox spacing="8.0">
                    <Label text="Date Lost:" styleClass="flyer-key"/>
                    <Label fx:id="flyerDate" styleClass="flyer-val" wrapText="true"/>
                </HBox>
                <HBox spacing="8.0">
                    <Label text="Last Seen:" styleClass="flyer-key"/>
                    <Label fx:id="flyerLocation" styleClass="flyer-val" wrapText="true"/>
                </HBox>
                <Label text="Description" styleClass="flyer-key"/>
                <Label fx:id="flyerDescription" styleClass="flyer-val" wrapText="true"/>
            </VBox>

            <Region prefHeight="4.0"/>
            <VBox styleClass="flyer-contact" spacing="4.0" alignment="CENTER">
                <Label text="IF FOUND, PLEASE CONTACT" styleClass="flyer-contact-title"/>
                <Label fx:id="flyerContact" styleClass="flyer-contact-info" wrapText="true" alignment="CENTER"/>
            </VBox>
        </VBox>
    </ScrollPane>

    <HBox styleClass="flyer-actions" spacing="10.0" alignment="CENTER">
        <Button text="🖨  Print" styleClass="btn-primary" onAction="#print"/>
        <Button text="⬇  Save as Image" styleClass="btn-secondary" onAction="#saveImage"/>
        <Button text="✕  Close" styleClass="btn-secondary" onAction="#close"/>
    </HBox>
</VBox>

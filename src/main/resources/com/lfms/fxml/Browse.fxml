<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.BrowseController" styleClass="root">
    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    <VBox styleClass="content-area" spacing="16.0" HBox.hgrow="ALWAYS">
        <Label text="Browse Items" styleClass="page-title"/>

        <HBox styleClass="filter-bar" spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search by name or description" HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="typeBox"/>
            <ComboBox fx:id="categoryBox"/>
            <TextField fx:id="locationField" promptText="Location"/>
            <Button text="Search" styleClass="btn-primary" onAction="#handleSearch"/>
            <Button text="Clear" styleClass="btn-secondary" onAction="#handleClear"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="imageCol" text="" prefWidth="70.0" sortable="false"/>
                <TableColumn fx:id="nameCol" text="Name" prefWidth="200.0"/>
                <TableColumn fx:id="categoryCol" text="Category" prefWidth="130.0"/>
                <TableColumn fx:id="typeCol" text="Type" prefWidth="90.0"/>
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120.0"/>
                <TableColumn fx:id="locationCol" text="Location" prefWidth="160.0"/>
                <TableColumn fx:id="dateCol" text="Date" prefWidth="110.0"/>
                <TableColumn fx:id="actionsCol" text="Actions" prefWidth="90.0" sortable="false"/>
            </columns>
        </TableView>
    </VBox>
</HBox>

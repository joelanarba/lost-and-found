<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.admin.AdminAuditLogController" styleClass="root">
    <fx:include fx:id="adminSidebar" source="AdminSidebar.fxml"/>
    <VBox styleClass="content-area" spacing="16.0" HBox.hgrow="ALWAYS">
        <Label text="Audit Log" styleClass="page-title"/>

        <HBox styleClass="filter-bar" spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search action, note or actor" HBox.hgrow="ALWAYS"/>
            <DatePicker fx:id="dateFrom" promptText="From"/>
            <DatePicker fx:id="dateTo" promptText="To"/>
            <Button text="Filter" styleClass="btn-primary" onAction="#handleFilter"/>
            <Button text="Clear" styleClass="btn-secondary" onAction="#handleClear"/>
            <Button text="Export CSV" styleClass="btn-secondary" onAction="#exportCsv"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="timestampCol" text="Timestamp" prefWidth="170.0"/>
                <TableColumn fx:id="actorCol" text="Actor" prefWidth="140.0"/>
                <TableColumn fx:id="actionCol" text="Action" prefWidth="150.0"/>
                <TableColumn fx:id="targetTypeCol" text="Target Type" prefWidth="110.0"/>
                <TableColumn fx:id="targetIdCol" text="Target ID" prefWidth="80.0"/>
                <TableColumn fx:id="noteCol" text="Note" prefWidth="340.0"/>
            </columns>
        </TableView>
    </VBox>
</HBox>

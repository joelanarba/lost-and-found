<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.admin.AdminUsersController" styleClass="root">
    <fx:include fx:id="adminSidebar" source="AdminSidebar.fxml"/>
    <VBox styleClass="content-area" spacing="16.0" HBox.hgrow="ALWAYS">
        <Label text="Users" styleClass="page-title"/>

        <HBox styleClass="filter-bar" spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search by name or email" HBox.hgrow="ALWAYS"/>
            <Button text="Export CSV" styleClass="btn-secondary" onAction="#exportCsv"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameCol" text="Name" prefWidth="160.0"/>
                <TableColumn fx:id="indexCol" text="Index No." prefWidth="110.0"/>
                <TableColumn fx:id="emailCol" text="Email" prefWidth="210.0"/>
                <TableColumn fx:id="roleCol" text="Role" prefWidth="90.0"/>
                <TableColumn fx:id="statusCol" text="Status" prefWidth="100.0"/>
                <TableColumn fx:id="dateCol" text="Date Joined" prefWidth="160.0"/>
                <TableColumn fx:id="actionsCol" text="Actions" prefWidth="200.0" sortable="false"/>
            </columns>
        </TableView>
    </VBox>
</HBox>

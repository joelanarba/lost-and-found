<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.admin.AdminReportsController" styleClass="root">
    <fx:include fx:id="adminSidebar" source="AdminSidebar.fxml"/>
    <VBox styleClass="content-area" spacing="16.0" HBox.hgrow="ALWAYS">
        <Label text="All Reports" styleClass="page-title"/>

        <HBox styleClass="filter-bar" spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search by name or description" HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="typeBox"/>
            <ComboBox fx:id="statusBox"/>
            <Button text="Search" styleClass="btn-primary" onAction="#handleSearch"/>
            <Button text="Export CSV" styleClass="btn-secondary" onAction="#exportCsv"/>
        </HBox>

        <TableView fx:id="table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idCol" text="ID" prefWidth="50.0"/>
                <TableColumn fx:id="typeCol" text="Type" prefWidth="80.0"/>
                <TableColumn fx:id="nameCol" text="Name" prefWidth="170.0"/>
                <TableColumn fx:id="categoryCol" text="Category" prefWidth="120.0"/>
                <TableColumn fx:id="reporterCol" text="Reported By" prefWidth="130.0"/>
                <TableColumn fx:id="statusCol" text="Status" prefWidth="120.0"/>
                <TableColumn fx:id="dateCol" text="Date" prefWidth="100.0"/>
                <TableColumn fx:id="actionsCol" text="Actions" prefWidth="290.0" sortable="false"/>
            </columns>
        </TableView>
    </VBox>
</HBox>

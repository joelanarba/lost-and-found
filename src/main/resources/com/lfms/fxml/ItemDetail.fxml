<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.ItemDetailController" styleClass="root">
    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    <ScrollPane fitToWidth="true" styleClass="content-scroll" HBox.hgrow="ALWAYS">
        <VBox styleClass="content-area" spacing="16.0">
            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <Button text="← Back" styleClass="btn-secondary" onAction="#goBack"/>
                <Label text="Item Details" styleClass="page-title"/>
            </HBox>

            <HBox spacing="24.0">
                <VBox spacing="14.0" alignment="TOP_CENTER">
                    <StackPane styleClass="image-frame">
                        <ImageView fx:id="imageView" fitWidth="280.0" fitHeight="280.0" preserveRatio="true"/>
                    </StackPane>

                    <VBox fx:id="qrPanel" styleClass="qr-panel" spacing="8.0" alignment="CENTER"
                          visible="false" managed="false">
                        <Label text="Scan to view this item" styleClass="qr-caption"/>
                        <StackPane styleClass="image-frame">
                            <ImageView fx:id="qrImageView" fitWidth="170.0" fitHeight="170.0" preserveRatio="true"/>
                        </StackPane>
                        <Button fx:id="saveQrButton" text="Save QR Code" styleClass="btn-secondary"
                                onAction="#saveQrCode"/>
                    </VBox>
                </VBox>

                <VBox styleClass="card" spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="nameLabel" text="Item name" styleClass="page-title" wrapText="true"/>
                    <HBox spacing="8.0">
                        <Label fx:id="typeBadge" text="TYPE"/>
                        <Label fx:id="statusBadge" text="STATUS"/>
                    </HBox>

                    <Region prefHeight="6.0"/>
                    <Label text="DESCRIPTION" styleClass="detail-key"/>
                    <Label fx:id="descLabel" styleClass="detail-value" wrapText="true"/>
                    <Label text="CATEGORY" styleClass="detail-key"/>
                    <Label fx:id="categoryLabel" styleClass="detail-value"/>
                    <Label text="LOCATION" styleClass="detail-key"/>
                    <Label fx:id="locationLabel" styleClass="detail-value"/>
                    <Label text="DATE REPORTED" styleClass="detail-key"/>
                    <Label fx:id="dateLabel" styleClass="detail-value"/>
                    <Label text="REPORTED BY" styleClass="detail-key"/>
                    <Label fx:id="reporterLabel" styleClass="detail-value"/>

                    <Region prefHeight="10.0"/>
                    <HBox fx:id="actionBar" spacing="10.0">
                        <Button fx:id="claimButton" text="Claim This Item" styleClass="btn-primary"
                                onAction="#claimItem" visible="false" managed="false"/>
                        <Button fx:id="printFlyerButton" text="🖨  Print Flyer" styleClass="btn-secondary"
                                onAction="#printFlyer" visible="false" managed="false"/>
                        <Button fx:id="editButton" text="Edit" styleClass="btn-secondary"
                                onAction="#editItem" visible="false" managed="false"/>
                        <Button fx:id="deleteButton" text="Delete" styleClass="btn-danger"
                                onAction="#deleteItem" visible="false" managed="false"/>
                    </HBox>
                </VBox>
            </HBox>

            <VBox fx:id="approvedPanel" styleClass="success-panel" spacing="6.0" maxWidth="560.0"
                  visible="false" managed="false">
                <Label text="Claim Approved! Contact the finder:" styleClass="success-panel-title"/>
                <Label fx:id="finderNameLabel" styleClass="detail-value"/>
                <Label fx:id="finderEmailLabel" styleClass="detail-value"/>
                <Label fx:id="finderPhoneLabel" styleClass="detail-value"/>
            </VBox>

            <Region prefHeight="6.0"/>
            <VBox fx:id="timelineBox" styleClass="card" spacing="16.0" maxWidth="560.0">
                <Label text="Item History" styleClass="section-title"/>
                <HBox fx:id="timelineRows" spacing="16.0" alignment="CENTER"/>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>

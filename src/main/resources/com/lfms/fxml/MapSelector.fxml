<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.lfms.controller.MapSelectorController"
            prefWidth="600.0" prefHeight="500.0">
    <center>
        <WebView fx:id="webView" prefWidth="600.0" prefHeight="450.0"/>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="20.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
            </padding>
            <Button mnemonicParsing="false" onAction="#confirmSelection" text="Confirm Location" styleClass="btn-primary"/>
            <Button mnemonicParsing="false" onAction="#cancelSelection" text="Cancel" styleClass="btn-secondary"/>
        </HBox>
    </bottom>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<HBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.lfms.controller.ReportFoundController" styleClass="root">
    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>
    <ScrollPane fitToWidth="true" styleClass="content-scroll" HBox.hgrow="ALWAYS">
        <VBox styleClass="content-area" spacing="14.0">
            <Label text="Report a Found Item" styleClass="page-title"/>
            <Label text="Found something? Report it so the owner can claim it."
                   styleClass="page-subtitle"/>

            <VBox styleClass="card" spacing="10.0" maxWidth="760.0">
                <HBox spacing="24.0">
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label text="Item Name *" styleClass="form-label"/>
                        <TextField fx:id="nameField" promptText="e.g. Set of keys with red tag"/>
                        <Label fx:id="nameError" styleClass="error-label" visible="false" managed="false"/>

                        <Label text="Category *" styleClass="form-label"/>
                        <ComboBox fx:id="categoryBox" maxWidth="Infinity"/>
                        <Label fx:id="categoryError" styleClass="error-label" visible="false" managed="false"/>

                        <Label text="Description *" styleClass="form-label"/>
                        <TextArea fx:id="descriptionArea" prefRowCount="4" wrapText="true"
                                  promptText="Describe the item in detail — colour, brand, size, any unique marks..."/>
                        <Label fx:id="descriptionError" styleClass="error-label" visible="false" managed="false"/>

                        <Label text="Location Found *" styleClass="form-label"/>
                        <TextField fx:id="locationField"
                                   promptText="Enter general area only, e.g. Main Library. Do not enter specific room."/>
                        <Label text="Enter the general area only — keep specific details private to verify claims."
                               styleClass="form-hint"/>
                        <Label fx:id="locationError" styleClass="error-label" visible="false" managed="false"/>

                        <Label text="Date Found" styleClass="form-label"/>
                        <DatePicker fx:id="datePicker" maxWidth="Infinity"/>
                    </VBox>

                    <VBox spacing="8.0" alignment="TOP_CENTER">
                        <Label text="Image *" styleClass="form-label"/>
                        <StackPane styleClass="image-frame">
                            <ImageView fx:id="imageView" fitWidth="200.0" fitHeight="200.0" preserveRatio="true"/>
                        </StackPane>
                        <Button text="Choose Image" styleClass="btn-secondary" onAction="#chooseImage"/>
                        <Label fx:id="imageError" styleClass="error-label" visible="false" managed="false"/>
                    </VBox>
                </HBox>

                <Region prefHeight="6.0"/>
                <HBox spacing="10.0">
                    <Button text="Submit Report" styleClass="btn-primary" onAction="#handleSubmit"/>
                    <Button text="Clear Form" styleClass="btn-secondary" onAction="#handleClear"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
